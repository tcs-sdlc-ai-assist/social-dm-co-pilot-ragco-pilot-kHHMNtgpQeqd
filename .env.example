# NextAuth.js Configuration
# The canonical URL of your site (e.g., http://localhost:3000 for local development)
NEXTAUTH_URL=http://localhost:3000

# A random secret used to encrypt tokens and sign cookies (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# OpenAI API Configuration
# Your OpenAI API key for generating DM response suggestions
OPENAI_API_KEY=

# The OpenAI model to use for generating responses (e.g., gpt-4, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4

# Salesforce OAuth2 Configuration
# The Connected App consumer key from Salesforce Setup
SALESFORCE_CLIENT_ID=

# The Connected App consumer secret from Salesforce Setup
SALESFORCE_CLIENT_SECRET=

# The base URL of your Salesforce instance (e.g., https://yourorg.my.salesforce.com)
SALESFORCE_INSTANCE_URL=

# The Salesforce username for API authentication
SALESFORCE_USERNAME=

# The Salesforce password (with security token appended if required) for API authentication
SALESFORCE_PASSWORD=

# SLA and Priority Configuration
# Number of minutes before a DM is considered to have breached the SLA response time
SLA_BREACH_MINUTES=60

# Confidence threshold (0.0 to 1.0) above which a message is flagged as high priority
HIGH_PRIORITY_THRESHOLD=0.8